{
  "name": "FinancialCategory",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome da categoria"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "Receita",
        "Despesa"
      ],
      "description": "Tipo da categoria"
    },
    "inquilino_id": {
      "type": "string",
      "description": "ID do Tenant ao qual esta categoria pertence"
    }
  },
  "required": [
    "nome",
    "tipo",
    "inquilino_id"
  ]
}